{
  "version": 2,
  "name": "vieos-project",
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/client/assets/$1"
    },
    {
      "src": "/favicons/(.*)",
      "dest": "/client/favicons/$1"
    },
    {
      "src": "/logos/(.*)",
      "dest": "/client/logos/$1"
    },
    {
      "src": "/photo/(.*)",
      "dest": "/client/photo/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/client/favicons/favicon.ico"
    },
    {
      "src": "/",
      "dest": "/client/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/client/index.html"
    }
  ]
}
